{
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "lib": ["ES2025", "DOM"],
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
"noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
